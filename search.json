[{"title":"Hello World","url":"/2025/05/11/hello-world/","content":"Welcome to Hexo! This is your very first post. Check documentation for more info. If you get any problems when using Hexo, you can find the answer in troubleshooting or you can ask me on GitHub.\nQuick StartCreate a new post$ hexo new &quot;My New Post&quot;\nMore info: Writing\nRun server$ hexo server\nMore info: Server\nGenerate static files$ hexo generate\nMore info: Generating\nDeploy to remote sites$ hexo deploy\nMore info: Deployment\n"},{"title":"hello","url":"/2025/05/11/hello/","content":""},{"title":"ʯͷ������","url":"/2025/05/15/%E7%9F%B3%E5%A4%B4%E5%89%AA%E5%88%80%E5%B8%83/","content":"#include &lt;stdio.h&gt;#include &lt;stdint.h&gt;#include &lt;time.h&gt;#include &lt;stdlib.h&gt; #define u32 uint32_t#define ROCK 1#define PAPER 2#define SCISSORS 3 void destemine_winner(u32 player_move, u32 computer_move)&#123;\t//�����ų�ƽ�ֵ����\tif (player_move == computer_move) &#123;\t\tputs(&quot;ƽ�֣�&quot;);\t\treturn;\t&#125; \t//����һ��ʤ���Ĺ���ӳ�䣬���м�����ҵ��ƶ���ֵ������ƶ����Դ�ܼ�������ƶ� \tu32 winning_moves[4] = &#123; 0, SCISSORS, ROCK, PAPER &#125;;\t//0��ռλ�� \t//winning_moves[1] SCISSORS\t//ROCK == 1\t//PAPER == 2\t//SCISSORS == 3\t\t//����player_move����ҵ��ƶ���winning_moves[player_move]����ǿ��Դ�ܼ�������ƶ�\t//����˵���ѡ1��ֻ�е������ѡ3ʱ�Ż��䣬��ô�ͽ�winning_moves�е�winning_moves[1]����λ3\tif (computer_move == winning_moves[player_move]) &#123;\t\tputs(&quot;��Ӯ�ˣ�&quot;);\t&#125;\telse &#123;\t\tputs(&quot;�����ˣ�&quot;);\t&#125;&#125; u32 get_player_choice() &#123;\tu32 choice;\tputs(&quot;��ѡ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);\tscanf_s(&quot;%d&quot;, &amp;choice); \twhile (choice &lt; ROCK || choice &gt; SCISSORS) &#123;\t\tputs(&quot;��Чѡ��������ѡ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);\t\tscanf_s(&quot;%d&quot;, &amp;choice);\t&#125; \treturn choice;&#125; u32 get_computer_choice() &#123;\treturn (rand() % (SCISSORS - ROCK + 1)) + ROCK;&#125; void print_instructions() &#123; \tputs(&quot;ʯͷ~����~������Ϸ��ʼ��&quot;);\tputs(&quot;�����������֣�ȷ����ȭ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);\tputs(&quot;==========================================&quot;);&#125;void print_choice(u32 choice) &#123;\tswitch (choice)\t&#123;\tcase ROCK: puts(&quot;ʯͷ&quot;); break;\tcase PAPER: puts(&quot;��&quot;); break;\tcase SCISSORS: puts(&quot;����&quot;); break;\t&#125;&#125; int main(void)&#123;\t//��ʼ�������������\tsrand(time(NULL)); \t//��ӡ��Ϸ˵��\tprint_instructions(); \t//��ȡ��Һͼ������ѡ��\tu32 player_choice = get_player_choice();\tu32 computer_choice = get_computer_choice(); \t//չʾ��Һͼ�������ѡ��\tputs(&quot;��ѡ����&quot;);\tprint_choice(player_choice);\tputs(&quot;�����ѡ����&quot;);\tprint_choice(computer_choice); \t//�ж�ȷ��Ӯ�ң�����չʾ\tdestemine_winner(player_choice, computer_choice); \treturn 0;&#125;","tags":["game"]}]