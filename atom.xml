#125;</span><br><span class="line"> </span><br><span class="line">u32 get_player_choice() &#123;</span><br><span class="line">u32 choice;</span><br><span class="line">puts(&quot;��ѡ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);</span><br><span class="line">scanf_s(&quot;%d&quot;, &amp;choice);</span><br><span class="line"> </span><br><span class="line">while (choice &lt; ROCK || choice &gt; SCISSORS) &#123;</span><br><span class="line">puts(&quot;��Чѡ��������ѡ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);</span><br><span class="line">scanf_s(&quot;%d&quot;, &amp;choice);</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">return choice;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">u32 get_computer_choice() &#123;</span><br><span class="line">return (rand() % (SCISSORS - ROCK + 1)) + ROCK;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">void print_instructions() &#123;</span><br><span class="line"> </span><br><span class="line">puts(&quot;ʯͷ~����~������Ϸ��ʼ��&quot;);</span><br><span class="line">puts(&quot;�����������֣�ȷ����ȭ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);</span><br><span class="line">puts(&quot;==========================================&quot;);</span><br><span class="line">&#125;</span><br><span class="line">void print_choice(u32 choice) &#123;</span><br><span class="line">switch (choice)</span><br><span class="line">&#123;</span><br><span class="line">case ROCK: puts(&quot;ʯͷ&quot;); break;</span><br><span class="line">case PAPER: puts(&quot;��&quot;); break;</span><br><span class="line">case SCISSORS: puts(&quot;����&quot;); break;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">int main(void)</span><br><span class="line">&#123;</span><br><span class="line">//��ʼ�������������</span><br><span class="line">srand(time(NULL));</span><br><span class="line"> </span><br><span class="