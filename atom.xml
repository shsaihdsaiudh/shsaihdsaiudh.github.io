    <title>ﾊｯﾍｷ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ</title>
    <link href="http://hexoproject.github.io/2025/05/15/%E7%9F%B3%E5%A4%B4%E5%89%AA%E5%88%80%E5%B8%83/"/>
    <id>http://hexoproject.github.io/2025/05/15/%E7%9F%B3%E5%A4%B4%E5%89%AA%E5%88%80%E5%B8%83/</id>
    <published>2025-05-15T07:34:48.000Z</published>
    <updated>2025-05-15T07:39:52.296Z</updated>
    
    <content type="html"><![CDATA[<figure class="highlight plaintext"><table><tr><td class="code"><pre><span class="line">#include &lt;stdio.h&gt;</span><br><span class="line">#include &lt;stdint.h&gt;</span><br><span class="line">#include &lt;time.h&gt;</span><br><span class="line">#include &lt;stdlib.h&gt;</span><br><span class="line"> </span><br><span class="line">#define u32 uint32_t</span><br><span class="line">#define ROCK 1</span><br><span class="line">#define PAPER 2</span><br><span class="line">#define SCISSORS 3</span><br><span class="line"> </span><br><span class="line">void destemine_winner(u32 player_move, u32 computer_move)</span><br><span class="line">&#123;</span><br><span class="line">//魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾅｳ魹ｽﾆｽ魹ｽﾖｵ魹ｽ魹ｽ魹ｽ魹ｽ</span><br><span class="line">if (player_move == computer_move) &#123;</span><br><span class="line">puts(&quot;ﾆｽ魹ｽﾖ｣魹ｽ&quot;);</span><br><span class="line">return;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">//魹ｽ魹ｽ魹ｽ魹ｽﾒｻ魹ｽ魹ｽﾊ､魹ｽ魹ｽ魹ｽﾄｹ魹ｽ魹ｽ魹ｽﾓｳ魹ｽ茱ｬ魹ｽ魹ｽ魹ｽﾐｼ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾒｵ魹ｽ魹ｽﾆｶ魹ｽ魹ｽ魹ｽﾖｵ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾆｶ魹ｽ魹ｽ魹ｽ魹ｽﾔｴ魹ｽﾜｼ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾆｶ魹ｽ</span><br><span class="line"> </span><br><span class="line">u32 winning_moves[4] = &#123; 0, SCISSORS, ROCK, PAPER &#125;;</span><br><span class="line">//0魹ｽ魹ｽﾕｼﾎｻ魹ｽ魹ｽ</span><br><span class="line"> </span><br><span class="line">//winning_moves[1] SCISSORS</span><br><span class="line">//ROCK == 1</span><br><span class="line">//PAPER == 2</span><br><span class="line">//SCISSORS == 3</span><br><span class="line"></span><br><span class="line">//魹ｽ魹ｽ魹ｽ魹ｽplayer_move魹ｽ魹ｽ魹ｽ魹ｽﾒｵ魹ｽ魹ｽﾆｶ魹ｽ魹ｽ魹ｽwinning_moves[player_move]魹ｽ魹ｽ魹ｽ魹ｽﾇｿ魹ｽ魹ｽﾔｴ魹ｽﾜｼ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾆｶ魹ｽ</span><br><span class="line">//魹ｽ魹ｽ魹ｽ魹ｽﾋｵ魹ｽ魹ｽ魹ｽﾑ｡1魹ｽ魹ｽﾖｻ魹ｽﾐｵ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾑ｡3ﾊｱ魹ｽﾅｻ魹ｽ魹ｽ茱ｬ魹ｽ魹ｽﾃｴ魹ｽﾍｽ魹ｽwinning_moves魹ｽﾐｵ魹ｽwinning_moves[1]魹ｽ魹ｽ魹ｽ魹ｽﾎｻ3</span><br><span class="line">if (computer_move == winning_moves[player_move]) &#123;</span><br><span class="line">puts(&quot;魹ｽ魹ｽﾓｮ魹ｽﾋ｣魹ｽ&quot;);</span><br><span class="line">&#125;</span><br><span class="line">else &#123;</span><br><span class="line">puts(&quot;魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾋ｣魹ｽ&quot;);</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">u32 get_player_choice() &#123;</span><br><span class="line">u32 choice;</span><br><span class="line">puts(&quot;魹ｽ魹ｽﾑ｡魹ｽ魹ｽ1魹ｽ魹ｽﾊｯﾍｷ魹ｽ魹ｽ2魹ｽﾇｲ魹ｽ魹ｽ魹ｽ3魹ｽﾇｼ魹ｽ魹ｽ魹ｽ&quot;);</span><br><span class="line">scanf_s(&quot;%d&quot;, &amp;choice);</span><br><span class="line"> </span><br><span class="line">while (choice &lt; ROCK || choice &gt; SCISSORS) &#123;</span><br><span class="line">puts(&quot;魹ｽ魹ｽﾐｧﾑ｡魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾑ｡魹ｽ魹ｽ1魹ｽ魹ｽﾊｯﾍｷ魹ｽ魹ｽ2魹ｽﾇｲ魹ｽ魹ｽ魹ｽ3魹ｽﾇｼ魹ｽ魹ｽ魹ｽ&quot;);</span><br><span class="line">scanf_s(&quot;%d&quot;, &amp;choice);</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">return choice;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">u32 get_computer_choice() &#123;</span><br><span class="line">return (rand() % (SCISSORS - ROCK + 1)) + ROCK;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">void print_instructions() &#123;</span><br><span class="line"> </span><br><span class="line">puts(&quot;ﾊｯﾍｷ‾魹ｽ魹ｽ魹ｽ魹ｽ‾魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾏｷ魹ｽ魹ｽﾊｼ魹ｽ魹ｽ&quot;);</span><br><span class="line">puts(&quot;魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾖ｣魹ｽﾈｷ魹ｽ魹ｽ魹ｽ魹ｽﾈｭ魹ｽ魹ｽ1魹ｽ魹ｽﾊｯﾍｷ魹ｽ魹ｽ2魹ｽﾇｲ魹ｽ魹ｽ魹ｽ3魹ｽﾇｼ魹ｽ魹ｽ魹ｽ&quot;);</span><br><span class="line">puts(&quot;==========================================&quot;);</span><br><span class="line">&#125;</span><br><span class="line">void print_choice(u32 choice) &#123;</span><br><span class="line">switch (choice)</span><br><span class="line">&#123;</span><br><span class="line">case ROCK: puts(&quot;ﾊｯﾍｷ&quot;); break;</span><br><span class="line">case PAPER: puts(&quot;魹ｽ魹ｽ&quot;); break;</span><br><span class="line">case SCISSORS: puts(&quot;魹ｽ魹ｽ魹ｽ魹ｽ&quot;); break;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">int main(void)</span><br><span class="line">&#123;</span><br><span class="line">//魹ｽ魹ｽﾊｼ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ</span><br><span class="line">srand(time(NULL));</span><br><span class="line"> </span><br><span class="line">//魹ｽ魹ｽﾓ｡魹ｽ魹ｽﾏｷﾋｵ魹ｽ魹ｽ</span><br><span class="line">print_instructions();</span><br><span class="line"> </span><br><span class="line">//魹ｽ魹ｽﾈ｡魹ｽ魹ｽﾒｺﾍｼ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾑ｡魹ｽ魹ｽ</span><br><span class="line">u32 player_choice = get_player_choice();</span><br><span class="line">u32 computer_choice = get_computer_choice();</span><br><span class="line"> </span><br><span class="line">//ﾕｹﾊｾ魹ｽ魹ｽﾒｺﾍｼ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾑ｡魹ｽ魹ｽ</span><br><span class="line">puts(&quot;魹ｽ魹ｽﾑ｡魹ｽ魹ｽ魹ｽ魹ｽ&quot;);</span><br><span class="line">print_choice(player_choice);</span><br><span class="line">puts(&quot;魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾑ｡魹ｽ魹ｽ魹ｽ魹ｽ&quot;);</span><br><span class="line">print_choice(computer_choice);</span><br><span class="line"> </span><br><span class="line">//魹ｽﾐｶ魹ｽﾈｷ魹ｽ魹ｽﾓｮ魹ｽﾒ｣魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾕｹﾊｾ</span><br><span class="line">destemine_winner(player_choice, computer_choice);</span><br><span class="line"> </span><br><span class="line">return 0;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>]]></content>
    
    
      
      
