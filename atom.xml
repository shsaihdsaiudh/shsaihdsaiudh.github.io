���ӳ�䣬���м�����ҵ��ƶ���ֵ������ƶ����Դ�ܼ�������ƶ�</span><br><span class="line"> </span><br><span class="line">u32 winning_moves[4] = &#123; 0, SCISSORS, ROCK, PAPER &#125;;</span><br><span class="line">//0��ռλ��</span><br><span class="line"> </span><br><span class="line">//winning_moves[1] SCISSORS</span><br><span class="line">//ROCK == 1</span><br><span class="line">//PAPER == 2</span><br><span class="line">//SCISSORS == 3</span><br><span class="line"></span><br><span class="line">//����player_move����ҵ��ƶ���winning_moves[player_move]����ǿ��Դ�ܼ�������ƶ�</span><br><span class="line">//����˵���ѡ1��ֻ�е������ѡ3ʱ�Ż��䣬��ô�ͽ�winning_moves�е�winning_moves[1]����λ3</span><br><span class="line">if (computer_move == winning_moves[player_move]) &#123;</span><br><span class="line">puts(&quot;��Ӯ�ˣ�&quot;);</span><br><span class="line">&#125;</span><br><span class="line">else &#123;</span><br><span class="line">puts(&quot;�����ˣ�&quot;);</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">u32 get_player_choice() &#123;</span><br><span class="line">u32 choice;</span><br><span class="line">puts(&quot;��ѡ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);</span><br><span class="line">scanf_s(&quot;%d&quot;, &amp;choice);</span><br><span class="line"> </span><br><span class="line">while (choice &lt; ROCK || choice &gt; SCISSORS) &#123;</span><br><span class="line">puts(&quot;��Чѡ��������ѡ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);</span><br><span class="line">scanf_s(&quot;%d&quot;, &amp;choice);</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">return choice;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">u32 get_computer_choice() &#123;</span><br><span class="line">return (rand() % (SCISSORS - ROCK + 1)) + ROCK;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">void print_instructions() &#123;</span><br><span class="line"> </span><br><span class="line">puts(&quot;ʯͷ~����~������Ϸ��ʼ��&quot;);</span><br><span class="line">puts(&quot;�����������֣�ȷ����ȭ��1��ʯͷ��2�ǲ���3�Ǽ���&quot;);</span><br><span class="line">puts(&quot;==========================================&quot;);</span><br><span class="line">&#125;</span><br><span class="line">void print_choice(u32 choice) &#123;</span><br><span class="line">switch (choice)</span><br><span class="line">&#123;</span><br><span class="line">case ROCK: puts(&quot;ʯͷ&quot;); break;</span><br><span class="line">case PAPER: puts(&quot;��&quot;); break;</span><br><span class="line">case SCISSORS: puts(&quot;����&quot;); break;</span><br><span class="line">&#125;</span><br><span class="line">&#125;</span><br><span class="line"> </span><br><span class="line">int main(void)</span><br><span class="line">&#123;</span><br><span class="line">//��ʼ�������������</span><br><span class="line">srand(time(NULL));</span><br><span class="line"> </span><br><span class="line">//��ӡ��Ϸ˵��</span><br><span class="line">print_instructions();</span><br><span class="line"> </span><br><span class="line">//��ȡ��Һͼ������ѡ��</span><br><span class="line">u32 player_choice = get_player_choice();</span><br><span class="line">u32 computer_choice = get_computer_choice();</span><br><span class="line"> </span><br><span class="line">//չʾ��Һͼ�������ѡ��</span><br><span class="line">puts(&quot;��ѡ����&quot;);</span><br><span class="line">print_choice(player_choice);</span><br><span class="line">puts(&quot;�����ѡ����&quot;);</span><br><span class="line">print_choice(computer_choice);</span><br><span class="line"> </span><br><span class="line">//�ж�ȷ��Ӯ�ң�����չʾ</span><br><span class="line">destemine_winner(player_choice, computer_choice);</span><br><span class="line"> </span><br><span class="line">return 0;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>]]></content>
    
    
      
      
